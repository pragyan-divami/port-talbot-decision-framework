# Port Talbot Decision Framework — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# ── AI PROVIDER (choose one) ──────────────────────────────────────────────────

# Option A: Groq (FREE — get key at console.groq.com, no credit card)
GROQ_API_KEY=gsk_your_key_here

# Option B: Anthropic Claude (paid — get key at console.anthropic.com)
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── LIVE KPI FEED (optional) ──────────────────────────────────────────────────
# Publish your Google Sheet as CSV and paste the URL here.
# Columns required: persona_id, kpi_code, val, rag
# SHEETS_CSV_URL=https://docs.google.com/spreadsheets/d/YOUR_ID/pub?output=csv

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=5000
DEBUG=false
